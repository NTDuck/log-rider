# -----------------------------------------------------------------------------
# Runtime mode
# -----------------------------------------------------------------------------
LOGRIDER_ENV=local
LOGRIDER_CONFIG_STRICT=true
LOGRIDER_ENABLE_DEMO=false
LOGRIDER_ENABLE_BENCHMARK_MODE=false
LOGRIDER_ENABLE_ML_CLASSIFIER=false

# -----------------------------------------------------------------------------
# Service ports
# -----------------------------------------------------------------------------
WEB_HOST=0.0.0.0
WEB_PORT=3001
INGEST_HTTP_HOST=0.0.0.0
INGEST_HTTP_PORT=8085
INGEST_GRPC_HOST=0.0.0.0
INGEST_GRPC_PORT=50051

# -----------------------------------------------------------------------------
# Redpanda
# -----------------------------------------------------------------------------
REDPANDA_IMAGE=docker.redpanda.com/redpandadata/redpanda:v23.2.19
REDPANDA_INTERNAL_BROKERS=redpanda:29092
REDPANDA_EXTERNAL_BROKERS=localhost:9092
REDPANDA_SMP=1
REDPANDA_MEMORY=768M
REDPANDA_CONTAINER_MEMORY=1g

KAFKA_TOPIC_LOGS_RECEIVED=logrider.logs.received.v1
KAFKA_TOPIC_LOGS_NORMALIZED=logrider.logs.normalized.v1
KAFKA_TOPIC_LOGS_PERSISTENCE_REQUESTED=logrider.logs.persistence-requested.v1
KAFKA_TOPIC_LOG_TAGS_ASSIGNED=logrider.logs.tags-assigned.v1
KAFKA_TOPIC_ALERT_CANDIDATES=logrider.alerts.candidate-detected.v1
KAFKA_TOPIC_DLQ_LOG_PERSISTENCE_FAILED=logrider.dlq.log-persistence-failed.v1
KAFKA_TOPIC_DLQ_TAG_WRITE_FAILED=logrider.dlq.log-tags-write-failed.v1

KAFKA_PARTITIONS_LOGS_RECEIVED=64
KAFKA_PARTITIONS_LOGS_NORMALIZED=16
KAFKA_PARTITIONS_LOGS_PERSISTENCE_REQUESTED=32
KAFKA_PARTITIONS_LOG_TAGS_ASSIGNED=16
KAFKA_PARTITIONS_ALERT_CANDIDATES=16
KAFKA_PARTITIONS_DLQ=3

KAFKA_GROUP_ROUTER=logrider.router.unified.v1
KAFKA_GROUP_LOG_EVENT_WRITER=logrider.persistence.log-events-writer.v1
KAFKA_GROUP_LOG_TAG_WRITER=logrider.persistence.log-tags-writer.v1
KAFKA_GROUP_ALERT_DEDUP=logrider.alerting.incident-dedup.v1
KAFKA_GROUP_CLASSIFIER=logrider.classification.tagger.v1
KAFKA_GROUP_ALERT_REALTIME_FORWARDER=logrider.realtime.alert-forwarder.v1

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_IMAGE=redis:7-alpine
REDIS_URL=redis://redis:6379
REDIS_CONTAINER_MEMORY=256m

REDIS_CHANNEL_LOG_REALTIME=logrider:realtime:log-events
REDIS_CHANNEL_ALERT_REALTIME=logrider:realtime:alert-events
REDIS_ZSET_TELEGRAM_DIRTY_INCIDENTS=logrider:notifications:telegram:dirty-incidents
REDIS_HASH_NOTIFICATION_DATA=logrider:notifications:recent:data
REDIS_ZSET_NOTIFICATION_INDEX=logrider:notifications:recent:index
REDIS_KEY_PREFIX_SESSION=logrider:sessions
REDIS_KEY_PREFIX_INCIDENT=logrider:incidents:active
REDIS_KEY_PREFIX_CONFIG=logrider:config
REDIS_KEY_PREFIX_TAG_CACHE=logrider:tags:cache

# -----------------------------------------------------------------------------
# ClickHouse
# -----------------------------------------------------------------------------
CLICKHOUSE_IMAGE=clickhouse/clickhouse-server:24.8
CLICKHOUSE_HOST=clickhouse
CLICKHOUSE_PORT=8123
CLICKHOUSE_USER=logrider
CLICKHOUSE_PASSWORD=change-me
CLICKHOUSE_DATABASE=logrider_analytics
CLICKHOUSE_CONTAINER_MEMORY=2g

CLICKHOUSE_TABLE_LOG_EVENTS=log_events
CLICKHOUSE_TABLE_LOG_EVENT_TAGS=log_event_tags
CLICKHOUSE_TABLE_APP_HEALTH_HOURLY=app_health_hourly
CLICKHOUSE_TABLE_LOG_INGEST_NULL=log_ingest_null

CLICKHOUSE_LOG_TTL_DAYS=7
CLICKHOUSE_MAX_QUERY_ROWS=5000
CLICKHOUSE_DASHBOARD_DEFAULT_ROWS=1000
CLICKHOUSE_QUERY_LOOKBACK_HOURS=6

# -----------------------------------------------------------------------------
# Postgres
# -----------------------------------------------------------------------------
POSTGRES_IMAGE=postgres:15-alpine
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=logrider
POSTGRES_PASSWORD=change-me
POSTGRES_DATABASE=logrider
POSTGRES_URI=postgres://logrider:change-me@postgres:5432/logrider
POSTGRES_CONTAINER_MEMORY=512m

# -----------------------------------------------------------------------------
# Security
# -----------------------------------------------------------------------------
SESSION_COOKIE_NAME=logrider_token
SESSION_TTL_SECONDS=86400
SESSION_SECRET=change-me-32-byte-minimum
INGEST_API_KEY=change-me-long-random-value
BCRYPT_COST=12
CORS_ALLOWED_ORIGINS=http://localhost:3001
SECURE_COOKIES=false
TRUST_PROXY=false

# -----------------------------------------------------------------------------
# Ingest limits
# -----------------------------------------------------------------------------
INGEST_MAX_RECORDS_PER_REQUEST=5000
INGEST_MAX_BODY_BYTES=5242880
INGEST_MAX_MESSAGE_BYTES=4096
INGEST_MAX_APPLICATION_NAME_BYTES=128
INGEST_REQUIRE_API_KEY=true

# -----------------------------------------------------------------------------
# Alerting
# -----------------------------------------------------------------------------
ALERT_DEDUP_TTL_SECONDS=60
ALERT_GROUPING_STRATEGY=app_message
ALERT_NOTIFICATION_TTL_SECONDS=86400
ALERT_RENOTIFY_COUNTS=1,10,50,100,500,1000
ALERT_MIN_UPDATE_INTERVAL_SECONDS=5
ALERT_ENABLED_SEVERITIES=ERROR,CRITICAL
ALERT_MAX_STORED_MESSAGE_BYTES=512

# -----------------------------------------------------------------------------
# Classifier
# -----------------------------------------------------------------------------
CLASSIFIER_BATCH_SIZE=256
CLASSIFIER_MAX_BATCH_WAIT_MS=1000
CLASSIFIER_CACHE_MAX_ENTRIES=50000
CLASSIFIER_CACHE_TTL_SECONDS=86400
CLASSIFIER_OVERLOAD_LAG_THRESHOLD=100000
CLASSIFIER_RECOVERY_LAG_THRESHOLD=20000
CLASSIFIER_MODEL_ID=kxshrx/infrnce-bert-classifier
OMP_NUM_THREADS=1
MKL_NUM_THREADS=1
TOKENIZERS_PARALLELISM=false
MALLOC_ARENA_MAX=2

# -----------------------------------------------------------------------------
# Telegram
# -----------------------------------------------------------------------------
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=disabled
TELEGRAM_LINK_TOKEN_TTL_SECONDS=300

# -----------------------------------------------------------------------------
# Benchmark/example
# -----------------------------------------------------------------------------
K6_IMAGE=grafana/k6:latest
EXAMPLE_DATA_DIR=example/data
BENCHMARK_RESULTS_DIR=benchmarks/results
ALERT_NOTIFICATION_TTL_SECONDS=86400
