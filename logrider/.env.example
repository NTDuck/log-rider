# ── Web Server ──────────────────────────────────────────────────────────────
SERVER_PORT=3000

# ── Redpanda / Kafka ─────────────────────────────────────────────────────────
REDPANDA_BROKERS=redpanda:29092

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ── ClickHouse ───────────────────────────────────────────────────────────────
CLICKHOUSE_HOST=clickhouse
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=password

# ── Postgres ─────────────────────────────────────────────────────────────────
POSTGRES_USER=logrider
POSTGRES_PASSWORD=password
POSTGRES_URI=postgres://logrider:password@postgres:5432/logrider

# ── Telegram ─────────────────────────────────────────────────────────────────
# Obtain a bot token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=

# ── Ingestion ────────────────────────────────────────────────────────────────
# API key required on the ingress endpoint (set in your ingest proxy/gateway)
INGEST_API_KEY=logrider-ingest-key

# ── Alert Deduplication ──────────────────────────────────────────────────────
# Number of occurrences within the TTL window before re-alerting
ALERT_THRESHOLD=100
